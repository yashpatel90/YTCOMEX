rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Default Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: blogs
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - slug: string (required, 1-200 chars)
    //   - content: string (required, 1-50000 chars)
    //   - excerpt: string (optional, 0-500 chars)
    //   - coverImage: string (optional, URL)
    //   - author: string (required, 1-100 chars)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (optional)
    //   - published: bool (optional)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // Collection: settings
    //   - global: site metadata (publicly readable)
    //   - private: API keys (admin only)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "yashpatel9090@gmail.com" && request.auth.token.email_verified == true) ||
          request.auth.token.firebase.sign_in_provider == 'anonymous'); // TEMPORARY: Allow anonymous login for iframe bypass
    }

    function isDocOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidBlog(data) {
      return data.keys().hasAll(['title', 'slug', 'content', 'author', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 50000 &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 100 &&
             data.createdAt is timestamp &&
             (!('excerpt' in data) || (data.excerpt is string && data.excerpt.size() <= 500)) &&
             (!('coverImage' in data) || (data.coverImage is string && data.coverImage.size() <= 1000)) &&
             (!('published' in data) || data.published is bool);
    }

    function isBlogUpdateValid() {
      return isValidBlog(request.resource.data) &&
             request.resource.data.createdAt == resource.data.createdAt; // Immutable createdAt
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isDocOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isDocOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if (resource != null && resource.data.published == true) || isAdmin();
      allow create: if isAdmin() && isValidBlog(request.resource.data);
      allow update: if isAdmin() && isBlogUpdateValid();
      allow delete: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/private {
      allow read, write: if isAdmin();
    }
  }
}

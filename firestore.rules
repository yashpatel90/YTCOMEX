rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: blogs
    // Fields:
    //   - title: string (required)
    //   - slug: string (required)
    //   - content: string (required)
    //   - excerpt: string (optional)
    //   - coverImage: string (optional)
    //   - author: string (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (optional)
    //   - published: bool (optional)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "yashpatel9090@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidBlog(data) {
      return data.keys().hasAll(['title', 'slug', 'content', 'author', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update: if isAdmin() && isValidBlog(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/private {
      allow read, write: if isAdmin();
    }
  }
}

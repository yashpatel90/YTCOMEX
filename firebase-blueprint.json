{
  "entities": {
    "blogs": {
      "title": "Blog Post",
      "description": "A blog post article on the website.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the blog post."
        },
        "slug": {
          "type": "string",
          "description": "The URL slug for the blog post."
        },
        "content": {
          "type": "string",
          "description": "The markdown content of the blog post."
        },
        "excerpt": {
          "type": "string",
          "description": "A short summary of the blog post."
        },
        "coverImage": {
          "type": "string",
          "description": "URL to the cover image."
        },
        "author": {
          "type": "string",
          "description": "The name of the author."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the post was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the post was last updated."
        },
        "published": {
          "type": "boolean",
          "description": "Whether the post is published."
        }
      },
      "required": ["title", "slug", "content", "author", "createdAt"]
    },
    "users": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["email", "role"]
    },
    "settings": {
      "title": "Site Settings",
      "description": "Global configuration for the website.",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "siteDescription": { "type": "string" },
        "contactEmail": { "type": "string" },
        "footerText": { "type": "string" }
      }
    }
  },
  "firestore": {
    "blogs": {
      "schema": "blogs",
      "description": "Collection of blog posts."
    },
    "users": {
      "schema": "users",
      "description": "Collection of user profiles."
    },
    "settings": {
      "schema": "settings",
      "description": "Global site settings."
    }
  }
}
